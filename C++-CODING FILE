#include <iostream>
#include <stack>
#include <string>

class Browser {
private:
    // Step 2: Create Back stack and Forward stack
    std::stack<std::string> back_stack;
    std::stack<std::string> forward_stack;
    std::string current_page;

public:
    // Step 3 & 6: Logic for opening a page
    void open_page(std::string url) {
        // Step 4: If a current page exists, store it in the Back stack
        if (!current_page.empty()) {
            back_stack.push(current_page);
        }

        // Step 5: Clear Forward stack
        while (!forward_stack.empty()) {
            forward_stack.pop();
        }

        // Step 6: Open new page
        current_page = url;
        std::cout << "Opened: " << current_page << std::endl;
    }

    void back_button() {
        // Step 7 & 8: Check if Back stack has pages
        if (!back_stack.empty()) {
            forward_stack.push(current_page); // Move current to Forward stack
            current_page = back_stack.top();  // Get previous page
            back_stack.pop();                 // Remove from Back stack
            std::cout << "Back to: " << current_page << std::endl;
        } else {
            std::cout << "Error: No back history available." << std::endl;
        }
    }

    void forward_button() {
        // Step 9 & 10: Check if Forward stack has pages
        if (!forward_stack.empty()) {
            back_stack.push(current_page);    // Move current to Back stack
            current_page = forward_stack.top(); // Get next page
            forward_stack.pop();               // Remove from Forward stack
            std::cout << "Forward to: " << current_page << std::endl;
        } else {
            std::cout << "Error: No forward history available." << std::endl;
        }
    }

    void display_status() {
        std::cout << "--- Current Page: " << (current_page.empty() ? "None" : current_page) << " ---" << std::endl;
    }
};

int main() {
    Browser myBrowser;

    // Simulating Steps 3 through 11
    myBrowser.open_page("home_page.com");   // Step 3
    myBrowser.open_page("google.com");      // Step 4-6
    myBrowser.open_page("github.com");      // Step 4-6

    myBrowser.back_button();                // Step 7-8: Returns to google.com
    myBrowser.back_button();                // Returns to home_page.com
    myBrowser.forward_button();             // Step 9-10: Moves to google.com
    
    myBrowser.open_page("openai.com");      // Step 5: This clears the forward history (github.com is lost)
    myBrowser.forward_button();             // Should show error

    return 0;
}
